# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here

# Facebook Ads Configuration
FACEBOOK_ACCESS_TOKEN=your-facebook-access-token
FACEBOOK_ACCOUNT_ID=your-facebook-account-id

# Google Ads Configuration
GOOGLE_DEVELOPER_TOKEN=your-google-developer-token
GOOGLE_CUSTOMER_ID=your-google-customer-id
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REFRESH_TOKEN=your-google-refresh-token

# Flask Configuration
FLASK_SECRET_KEY=your-super-secret-key-here
FLASK_ENV=production

# Database Configuration
DATABASE_URL=sqlite:///robo_otimizador.db

# Optional: Manus AI Configuration
MANUS_API_KEY=your-manus-api-key-here

# Optional: Email Configuration (for notifications)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-email-password

# Optional: Webhook URLs
WEBHOOK_URL=https://your-webhook-url.com/webhook
